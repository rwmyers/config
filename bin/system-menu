#!/usr/bin/env bash

# Allow jumping directly to a submenu via argument
BACK_TO_EXIT=false

back_to() {
    local parent_menu="$1"
    if [[ $BACK_TO_EXIT == "true" ]]; then
        exit 0
    elif [[ -n $parent_menu ]]; then
        "$parent_menu"
    else
        show_main_menu
    fi
}

menu() {
    local prompt="$1"
    local options="$2"
    echo -e "$options" | walker --dmenu 2>/dev/null
}

show_system_menu() {
    local selection
    selection=$(menu "System" "󰌾  Lock\n󰒲  Suspend\n󰍃  Logout\n󰜉  Restart\n󰐥  Shutdown")

    case $selection in
        *Lock*)
            swaylock -f -c 000000
            ;;
        *Suspend*)
            systemctl suspend
            ;;
        *Logout*)
            hyprctl dispatch exit
            ;;
        *Restart*)
            systemctl reboot
            ;;
        *Shutdown*)
            systemctl poweroff
            ;;
        *)
            back_to show_main_menu
            ;;
    esac
}

show_update_menu() {
    local selection
    selection=$(menu "Update" "Restart Walker\nRestart Hyprland")

    case $selection in
        *Walker*)
            walker-restart
            ;;
        *Hyprland*)
            hyprctl reload
            ;;
        *)
            back_to show_main_menu
            ;;
    esac
}

THEMES_DIR="$HOME/themes"

show_theme_menu() {
    local current_theme themes selection
    current_theme=$(readlink "$THEMES_DIR/current")

    # List theme directories, excluding 'current'
    themes=$(find -L "$THEMES_DIR" -mindepth 1 -maxdepth 1 -type d -not -name current -printf '%f\n' | sort)

    selection=$(echo "$themes" | walker --dmenu 2>/dev/null)

    if [[ -n $selection && $selection != "CNCLD" ]]; then
        ln -snf "$selection" "$THEMES_DIR/current"
        hyprctl reload
        swaybg -i "$THEMES_DIR/current/background" &
        walker-restart
    else
        back_to show_main_menu
    fi
}

show_web_menu() {
    local selection
    selection=$(menu "Web" "󰍉  Websearch\n󰃀  Bookmarks")

    case $selection in
        *Websearch*)
            walker -m websearch
            ;;
        *Bookmarks*)
            walker -m bookmarks
            ;;
        *)
            back_to show_main_menu
            ;;
    esac
}

show_main_menu() {
    local selection
    selection=$(menu "Go" "󰀻  Apps\n󰖟  Web\n󰸌  Themes\n󰑐  Update\n󰐥  System")

    case $selection in
        *Apps*)
            walker
            ;;
        *Web*)
            show_web_menu
            ;;
        *Themes*)
            show_theme_menu
            ;;
        *Update*)
            show_update_menu
            ;;
        *System*)
            show_system_menu
            ;;
    esac
}

if [[ -n $1 ]]; then
    BACK_TO_EXIT=true
    case "${1,,}" in
        system) show_system_menu ;;
        web) show_web_menu ;;
        themes) show_theme_menu ;;
        update) show_update_menu ;;
        *) show_main_menu ;;
    esac
else
    show_main_menu
fi
