#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<EOF
Usage: $(basename "$0") --lid <0|1>

Point ~/.config/hypr/monitors.conf at the right config in
~/.config/hypr/monitors/ and reload Hyprland.

  --lid 0   Lid closed -> monitors/lidclosed.conf
  --lid 1   Lid open   -> monitors/default.conf
EOF
    exit "${1:-1}"
}

lid=""
while [ $# -gt 0 ]; do
    case "$1" in
        --lid) lid="${2:-}"; shift 2 ;;
        -h|--help) usage 0 ;;
        *) echo "unknown arg: $1" >&2; usage ;;
    esac
done

case "$lid" in
    0) target="lidclosed.conf" ;;
    1) target="default.conf" ;;
    *) echo "--lid must be 0 or 1" >&2; usage ;;
esac

monitors_dir="$HOME/.config/hypr/monitors"
link="$HOME/.config/hypr/monitors.conf"
target_path="$monitors_dir/$target"

if [ ! -f "$target_path" ]; then
    echo "missing config: $target_path" >&2
    exit 2
fi

ln -sfn "$target_path" "$link"
hyprctl reload >/dev/null
